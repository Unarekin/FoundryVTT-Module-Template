    "@types/Foundry-VTT": "https://github.com/League-of-Foundry-Developers/foundry-vtt-types.git",
    "@types/cypress": "^1.1.3",
    "@types/eslint__js": "^8.42.3",
    "@types/handlebars": "^4.1.0",
    "@types/node": "^22.7.5",
    "@types/path-browserify": "^1.0.3",
    "@types/unzipper": "^0.10.10",
    "babel-loader": "^9.2.1",
    "cypress-ct-html": "^1.1.0",
