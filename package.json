{
  "name": "foundryvtt-module-template",
  "version": "0.0.4",
  "description": "",
  "main": "dist/module.js",
  "scripts": {
    "test": "npx start-server-and-test start-server http://localhost:30000 cy:run",
    "cy:run": "npx cypress run --browser chrome",
    "cy:open": "npx cypress open",
    "test:e2e": "npx start-server-and-test start-server http://localhost:30000 test:e2e:open",
    "test:component": "npx start-server-and-test start-server http://localhost:30000 test:component:open",
    "test:e2e:open": "npx cypress open --e2e --browser chrome",
    "test:component:open": "npx cypress run --component --browser chrome",
    "build": "./build.mjs",
    "build:prod": "NODE_ENV=production ./build.mjs",
    "watch": "npx onchange 'src/**/*' -- yarn build",
    "start-server": "node ./run-server.mjs"
  },
  "author": "Unarekin",
  "license": "MIT",
  "devDependencies": {
