    "esbuild-copy-static-files": "^0.1.0",
    "esbuild-node-externals": "^1.14.0",
    "esbuild-plugin-clean": "^1.0.1",
    "esbuild-plugin-json-merge": "^0.1.0",
    "esbuild-sass-plugin": "^3.3.1",
    "eslint": "^9.11.0",
    "glob": "^11.0.0",
    "handlebars": "^4.7.8",
